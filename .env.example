# Database
DATABASE_URL=sqlite+aiosqlite:///./data/kr8bit.db

# Scraper
SCRAPER_BASE_URL=https://fitgirl-repacks.site
SCRAPER_POSTS_PER_PAGE=100
SCRAPER_DELAY_SECONDS=1.0
SCRAPE_INTERVAL_HOURS=6

# qBittorrent (also configurable via Settings page in the UI)
QBITTORRENT_HOST=http://localhost:8090
QBITTORRENT_USER=admin
QBITTORRENT_PASS=adminadmin
QBIT_SYNC_INTERVAL_SECONDS=30

# Enrichment
ENRICHMENT_ENABLED=true
ENRICHMENT_BATCH_SIZE=50
ENRICHMENT_CONCURRENCY=10
IGDB_RATE_LIMIT=4

# IGDB / Twitch (also configurable via Settings page in the UI)
# Sign up at https://dev.twitch.tv/console to get these credentials
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# SteamGridDB (optional - for game artwork)
# Get your API key at https://www.steamgriddb.com/profile/api
STEAMGRIDDB_API_KEY=
