# Library
LIBRARY_ROOT=/games

# Persistence
CACHE_DIR=/data/cache
DB_PATH=/data/kr8bit.db
DATABASE_URL=file:/data/kr8bit.db

# HTTP
PORT=8080
HOST=0.0.0.0

# Logging
LOG_LEVEL=info

# IGDB (optional second metadata provider; omit to disable)
# IGDB_CLIENT_ID=
# IGDB_CLIENT_SECRET=
# IGDB_API_BASE=https://api.igdb.com/v4
# IGDB_TOKEN_BASE=https://id.twitch.tv/oauth2
# IGDB_HTTP_TIMEOUT_MS=15000

# Steam App Index (optional — speeds up search with a local app list)
# Without this, search uses live Steam storesearch (slightly slower but works fine)
# Get a key at https://steamcommunity.com/dev/apikey
# STEAM_API_KEY=

# SteamGridDB Artwork (optional — replaces default Steam artwork with community grids)
# Without this, games use Steam CDN cover/header images
# Get a key at https://www.steamgriddb.com/profile/preferences/api
# STEAMGRIDDB_API_KEY=