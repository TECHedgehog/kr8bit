generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Game {
  id          String  @id @default(uuid())
  entryPath   String  @unique
  entryType   String // EntryType enum mirror: ARCHIVE | DIRECTORY
  entryName   String
  sizeBytes   BigInt
  steamAppId  Int?
  title       String?
  releaseYear Int?
  description String?
  developers  String // JSON-encoded string[]
  publishers  String // JSON-encoded string[]
  genres      String // JSON-encoded string[]
  coverUrl    String?
  headerUrl   String?

  matchStatus String // MatchStatus enum mirror: PENDING | FLAGGED | ACCEPTED | MANUAL | REJECTED
  matchScore  Float?
  matchedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([matchStatus])
  @@index([steamAppId])
}

model ScanRun {
  id         String    @id @default(uuid())
  rootPath   String
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  found      Int       @default(0)
  added      Int       @default(0)
  updated    Int       @default(0)
  failed     Int       @default(0)
  status     String // ScanStatus enum mirror: RUNNING | DONE | FAILED
  errors     String // JSON-encoded string[]
}

model Setting {
  key   String @id
  value String
}